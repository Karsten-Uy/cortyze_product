# Inference mode — select which client serves /analyze requests.
#   mock   (default) — MockRunPodClient: synthetic predictions or saved
#                      fixture. $0, deterministic. Great for frontend dev
#                      and unit tests. RunPod env vars below can stay set
#                      and won't take effect until INFERENCE_MODE=runpod.
#   runpod          — real GPU. Auto-picks Pod mode if RUNPOD_POD_URL is
#                      set, else Serverless if both RUNPOD_ENDPOINT_ID and
#                      RUNPOD_API_KEY are set.
INFERENCE_MODE=mock

# HuggingFace — gated facebook/tribev2 access
HF_TOKEN=

# RunPod — GPU inference (used only when INFERENCE_MODE=runpod, Stage 1.2)
# Pod mode (set this for direct HTTP to a deployed Pod's /predict):
RUNPOD_POD_URL=
# Serverless mode (set both for the runsync endpoint):
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# S3-compatible object storage (Stage 1 §5.2)
# STORAGE_MODE picks the backend explicitly:
#   off    — no client; uploads disabled, /analyze runs in mock-storage mode
#   minio  — local MinIO via S3_ENDPOINT_URL (use scripts/dev_minio.sh)
#   r2     — Cloudflare R2; endpoint derived from R2_ACCOUNT_ID
#
# The R2_* var names are reused by both backends — only STORAGE_MODE
# decides which endpoint and credentials get applied.
STORAGE_MODE=minio

# MinIO defaults (used when STORAGE_MODE=minio):
S3_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin

# R2 production (used when STORAGE_MODE=r2; set R2_ACCESS_KEY/R2_SECRET_KEY
# from your Cloudflare R2 token, not minioadmin):
R2_ACCOUNT_ID=

# Bucket names — same on both backends:
R2_BUCKET_UPLOADS=cortyze-uploads
R2_BUCKET_PREDICTIONS=cortyze-predictions

# Supabase Postgres — reports table (Stage 1 §5.2)
DATABASE_URL=

# CORS — allowed frontend origins, comma-separated
FRONTEND_ORIGINS=http://localhost:3000

# Stage 2 — Suggestion LLM (services/suggestions/llm/)
# Pick the LLM provider that powers /analyze suggestions. `mock` is free
# and ships templated suggestions for frontend dev.
#
#   mock                — MockLLMClient (default; templated, free, deterministic)
#   openai_compatible   — talks to OpenAI / vLLM / Ollama / Groq / Together
#   anthropic           — native Claude SDK with prompt caching
ENABLE_SUGGESTIONS=true
SUGGESTION_LLM_MODE=mock

# OpenAI-compatible config (used when SUGGESTION_LLM_MODE=openai_compatible)
# Examples:
#   Ollama:    LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=qwen2.5:7b-instruct  LLM_API_KEY=ollama
#   vLLM:      LLM_BASE_URL=http://your-pod:8001/v1     LLM_MODEL=Qwen/Qwen2.5-32B-AWQ  LLM_API_KEY=anything
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini           LLM_API_KEY=sk-...
#   Groq:      LLM_BASE_URL=https://api.groq.com/openai/v1                              LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TEMPERATURE=0.5

# Anthropic native config (used when SUGGESTION_LLM_MODE=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
